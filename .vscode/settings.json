{
  // =============================================================
  // VS Code — настройки рабочего пространства TheDay Client
  // Рекомендуемые расширения (установи вручную через Extensions):
  //   - "HTMLHint"          (id: mkaufman.HTMLHint)       — линтер HTML
  //   - "stylelint"         (id: stylelint.vscode-stylelint) — линтер CSS
  //   - "ESLint"            (id: dbaeumer.vscode-eslint)  — линтер JS
  //   - "Prettier"          (id: esbenp.prettier-vscode)  — форматирование
  //   - "GitLens"           (id: eamodio.gitlens)         — история изменений
  //   - "Live Server"       (id: ritwickdey.LiveServer)   — локальный сервер
  //     ОСТОРОЖНО с Live Server: не используй на продакшн-данных,
  //     только для локальной разработки
  // =============================================================

  // ===== ФОРМАТИРОВАНИЕ =====
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": false,
  "files.insertFinalNewline": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // ===== HTMLHINT — правила безопасности HTML =====
  "htmlhint.options": {
    // Запрет дублирующихся id (потенциальный вектор DOM-атак)
    "id-unique": true,
    // Все теги должны быть закрыты
    "tag-pair": true,
    // Атрибуты в нижнем регистре
    "attr-lowercase": true,
    // Значения атрибутов в кавычках
    "attr-value-double-quotes": true,
    // Запрет пустых атрибутов href (потенциальный XSS)
    "href-abs-or-rel": false,
    // DOCTYPE обязателен
    "doctype-first": true,
    // Запрет inline-обработчиков событий (onclick=, onerror= и т.д.)
    // ВАЖНО: это помогает избежать XSS через атрибуты
    "inline-style-disabled": false,
    "inline-script-disabled": false,
    // Charset должен быть первым мета-тегом
    "head-script-disabled": false,
    "spec-char-escape": true
  },

  // ===== STYLELINT — правила безопасности CSS =====
  "stylelint.enable": true,
  "css.validate": true,
  "scss.validate": true,
  "less.validate": true,

  // ===== ESLINT — правила безопасности JS =====
  "eslint.enable": true,
  "eslint.options": {
    "rules": {
      // Запрет eval() — главный вектор XSS через JS
      "no-eval": "error",
      // Запрет new Function() — аналог eval
      "no-new-func": "error",
      // Запрет небезопасного innerHTML без санитизации
      "no-unsanitized/property": "off",
      // Предупреждение о console.log (утечка данных в продакшн)
      "no-console": "warn"
    }
  },

  // ===== ФАЙЛЫ — исключения из поиска/индексации =====
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/*.log": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true
  },

  // ===== БЕЗОПАСНОСТЬ РАБОЧЕГО ПРОСТРАНСТВА =====
  // Запрет автоматического выполнения задач при открытии папки
  "task.allowAutomaticTasks": "off",

  // Предупреждение при открытии ненадёжных рабочих пространств
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.untrustedFiles": "prompt",

  // ===== LIVE SERVER (если установлен) =====
  "liveServer.settings.donotShowInfoMsg": true,
  // Открывать только на localhost, не на 0.0.0.0
  "liveServer.settings.host": "127.0.0.1",
  "liveServer.settings.port": 5500,
  // HTTPS для Live Server (требует сертификат)
  "liveServer.settings.https": {
    "enable": false
  },

  // ===== PRETTIER — форматирование =====
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "prettier.singleQuote": true,
  "prettier.semi": true,
  "prettier.printWidth": 100,
  "prettier.trailingComma": "es5"
}
