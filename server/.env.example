# ============================================================
# TheDay Server — переменные окружения
# Скопируй этот файл в .env и заполни значения
# ============================================================

# Порт сервера
PORT=3001

# Режим (development показывает OTP коды в ответе, production — нет)
NODE_ENV=development

# JWT секрет (сгенерируй случайную строку 64+ символов)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_64chars

# Секрет для админ-панели
ADMIN_SECRET=your_admin_secret_here

# Секрет для лаунчера
LAUNCHER_SECRET=your_launcher_secret_here

# ---- SMTP (отправка писем) ----
# Для Gmail: включи "Пароли приложений" в настройках Google аккаунта
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="TheDay Client <your_email@gmail.com>"

# ---- Для Yandex ----
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=your@yandex.ru
# SMTP_PASS=your_password

# ---- Для Mail.ru ----
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@mail.ru
# SMTP_PASS=your_password

# Разрешённый origin для CORS (оставь * для разработки)
ALLOWED_ORIGIN=*

# Время жизни OTP кода (минуты)
OTP_EXPIRES_MIN=10
